@model IEnumerable<PlataformaCreditos.Models.SolicitudCredito>

@{
    ViewData["Title"] = "Panel Analista";
}

<h1>Solicitudes Pendientes</h1>

<div class="row">
    @foreach (var solicitud in Model)
    {
        <div class="col-md-6">
            @await Html.PartialAsync("_SolicitudesPartial", solicitud)
        </div>
    }
</div>

@if (TempData["Ok"] != null)
{
    <div class="alert alert-success mt-3">@TempData["Ok"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-3">@TempData["Error"]</div>
}
