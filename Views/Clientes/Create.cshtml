@model PlataformaCreditos.Models.Cliente

<h2>Crear Cliente</h2>

<form asp-action="Create">
    <div class="form-group">
        <label asp-for="UsuarioId"></label>
        <input asp-for="UsuarioId" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="IngresosMensuales"></label>
        <input asp-for="IngresosMensuales" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Activo"></label>
        <input asp-for="Activo" type="checkbox" />
    </div>
    <button type="submit" class="btn btn-success">Guardar</button>
</form>
