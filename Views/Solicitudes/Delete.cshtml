@model PlataformaCreditos.Models.SolicitudCredito

<h2>Eliminar Solicitud</h2>

<div>
    <p>¿Seguro que deseas eliminar esta solicitud?</p>
    <p><strong>Cliente:</strong> @Model.Cliente.UsuarioId</p>
    <p><strong>Monto:</strong> @Model.MontoSolicitado</p>
    <p><strong>Estado:</strong> @Model.Estado</p>
</div>

<form asp-action="DeleteConfirmed">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

