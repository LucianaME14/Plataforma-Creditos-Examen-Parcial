@model PlataformaCreditos.Models.SolicitudCredito

<h2>Editar Solicitud</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />
    <div class="form-group">
        <label asp-for="MontoSolicitado"></label>
        <input asp-for="MontoSolicitado" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Estado"></label>
        <select asp-for="Estado" class="form-control">
            <option value="0">Pendiente</option>
            <option value="1">Aprobado</option>
            <option value="2">Rechazado</option>
        </select>
    </div>
    <div class="form-group">
        <label asp-for="MotivoRechazo"></label>
        <input asp-for="MotivoRechazo" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</form>
